# Environment variables for Notex
# Copy this file to .env and fill in your values

# ────────────────────────────────────────
# Environment
# ────────────────────────────────────────
ENV=development
DEBUG=true

# ────────────────────────────────────────
# Database
# ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://notex:notex@localhost:5432/notex

# ────────────────────────────────────────
# Redis
# ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ────────────────────────────────────────
# Celery
# ────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ────────────────────────────────────────
# LLM Provider
# ────────────────────────────────────────
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ────────────────────────────────────────
# MCP (Model Context Protocol)
# ────────────────────────────────────────
MCP_ENABLED=true
MCP_SERVER_URL=http://mcp_http:8001/sse

# ────────────────────────────────────────
# Logging
# ────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console

# ────────────────────────────────────────
# CORS
# ────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ────────────────────────────────────────
# Business Logic
# ────────────────────────────────────────
CONTEXT_MESSAGE_LIMIT=20
RESOLVER_CONFIDENCE_THRESHOLD=0.65
RESOLVER_TIME_WINDOW_MINUTES=45
RESOLVER_MAX_CANDIDATES=5

# ────────────────────────────────────────
# Authentication
# ────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=7200
REFRESH_TOKEN_TTL_SECONDS=2592000

# ────────────────────────────────────────
# Push Notifications (OneSignal)
# notification_token in Device model stores OneSignal player_id / subscription_id
# ────────────────────────────────────────
NOTIFICATIONS_ENABLED=true
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
ONESIGNAL_API_BASE=https://onesignal.com/api/v1
